generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// prisma/schema.prisma
model User {
  id      Int      @id @default(autoincrement())
  name    String
  sex     String?  // 可选，值为 'male'/'female'/'other'
  address String?
  photo   String?  // 存储图片路径或 URL
}